--!strict
--!native
--!optimize 2

export type Mode = "Safe" | "Snap"

export type GuardConfig = {
	ENABLED: boolean,
	MAX_FRAME_BYTES: number,
	MAX_PACKETS_PER_SECOND: number,
	MAX_INVOKES_PER_SECOND: number,
	MAX_PENDING_INVOKES: number,
	INVOKE_TIMEOUT: number,
	KICK_ON_REPEATED_VIOLATIONS: boolean,
	VIOLATION_KICK_THRESHOLD: number,
}

local MODE: Mode = "Snap"

local IS_SNAP_MODE = MODE == "Snap"

local GUARD_SAFE: GuardConfig = {
	ENABLED = true,
	MAX_FRAME_BYTES = 131072,
	MAX_PACKETS_PER_SECOND = 2000,
	MAX_INVOKES_PER_SECOND = 60,
	MAX_PENDING_INVOKES = 256,
	INVOKE_TIMEOUT = 10,
	KICK_ON_REPEATED_VIOLATIONS = false,
	VIOLATION_KICK_THRESHOLD = 10,
}

local GUARD_SNAP: GuardConfig = {
	ENABLED = false,
	MAX_FRAME_BYTES = 262144,
	MAX_PACKETS_PER_SECOND = 10000,
	MAX_INVOKES_PER_SECOND = 240,
	MAX_PENDING_INVOKES = 512,
	INVOKE_TIMEOUT = 10,
	KICK_ON_REPEATED_VIOLATIONS = false,
	VIOLATION_KICK_THRESHOLD = 10,
}

local GUARD = if IS_SNAP_MODE then table.freeze(GUARD_SNAP) else table.freeze(GUARD_SAFE)

local Settings = {
	MODE = MODE,
	IS_SNAP_MODE = IS_SNAP_MODE,
	IS_FAST = IS_SNAP_MODE,

	USE_XPCALL = not IS_SNAP_MODE,
	VALIDATE_FRAMES = not IS_SNAP_MODE,
	OMIT_FIXED_LENGTH = IS_SNAP_MODE,
	OMIT_OUTER_LENGTH_PREFIX = IS_SNAP_MODE,
	BANDWIDTH_TRACKING = not IS_SNAP_MODE,

	READY_TIMEOUT = 15,
	MAX_PREREADY_QUEUE_BYTES = 524288,
	EARLY_FLUSH_ENABLED = false,
	EARLY_FLUSH_INVOKE_ONLY = false,

	GUARD = GUARD,
}

return table.freeze(Settings)
